# Copier vers .env.local pour le développement
# Pour le déploiement Docker, passer ces variables dans le docker-compose.yml

# LLM — requis uniquement pour les fonctionnalités IA (Phase 2)
# IMPORTANT : si ANTHROPIC_API_KEY est déjà défini dans l'environnement système,
# Next.js ne le surcharge pas. Désinstaller l'env système ou l'ajouter manuellement.
ANTHROPIC_API_KEY=sk-ant-...

# Base de données
DB_PATH=./data/cave.sqlite

# Photos d'étiquettes
LABELS_DIR=./labels

# Auth — générer un secret aléatoire : openssl rand -base64 32
SESSION_SECRET=changez-moi-min-32-caracteres-aleatoires

# Hash bcrypt du mot de passe
# Générer avec : node -e "const b = require('bcryptjs'); b.hash('votremotdepasse', 12).then(console.log)"
# IMPORTANT : les $ doivent être échappés avec \$ dans ce fichier (expansion dotenv)
# Exemple : \$2b\$12\$VOTRE_HASH_ICI
APP_PASSWORD_HASH=\$2b\$12\$...

NODE_ENV=development
